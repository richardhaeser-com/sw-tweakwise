export default "{% block sw_cms_element_dailymotion_config %}\n    <sw-tabs\n        position=\"left\"\n        default-item=\"data\"\n    >\n        <template #default=\"{ active }\">\n            <sw-tabs-item name=\"data\" :active-tab=\"active\">\n                {{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.tab.data') }}\n            </sw-tabs-item>\n            <sw-tabs-item name=\"display\" :active-tab=\"active\">\n                {{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.tab.display') }}\n            </sw-tabs-item>\n        </template>\n\n        <template #content=\"{ active }\">\n            <template v-if=\"active === 'data'\">\n                <sw-text-field\n                    v-model=\"groupId\"\n                    class=\"swag-groupid-field\"\n                    :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.groupId.label')\"\n                    :help-text=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.groupId.helpText')\"\n                    required\n                    :placeholder=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.groupId.placeHolder')\"\n                    @input=\"onElementUpdate\"\n                    @change=\"onElementUpdate\"\n                    @update:value=\"onElementUpdate\"\n                >\n                </sw-text-field>\n            </template>\n\n            <template v-if=\"active === 'display'\">\n                <sw-alert variant=\"info\" :closable=\"false\">\n                    {{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.display.overrideNotice') }}\n                </sw-alert>\n                <div class=\"sw-cms-el-config-tweakwise-featured-products__display-grid\">\n\n                    <div>\n                        <div class=\"sw-cms-el-config-tweakwise-featured-products__display-column-header\">\n                            <sw-icon name=\"regular-desktop\" small></sw-icon>\n                            {{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.device.desktop') }}\n                        </div>\n                        <sw-select-field\n                            v-model:value=\"viewDesktop\"\n                            size=\"small\"\n                            :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.label')\"\n                            :placeholder=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.placeholder')\"\n                            @change=\"onElementUpdate\"\n                        >\n                            <option value=\"carousel\">{{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.carousel') }}</option>\n                            <option value=\"grid\">{{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.grid') }}</option>\n                        </sw-select-field>\n                        <sw-number-field\n                            v-model:value=\"itemsDesktop\"\n                            size=\"small\"\n                            :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.items.label')\"\n                            number-type=\"int\"\n                            :min=\"1\"\n                            :allow-empty=\"true\"\n                            :disabled=\"viewDesktop === 'grid'\"\n                            @change=\"onElementUpdate\"\n                            @update:value=\"onElementUpdate\"\n                        >\n                        </sw-number-field>\n                    </div>\n\n                    <div>\n                        <div class=\"sw-cms-el-config-tweakwise-featured-products__display-column-header\">\n                            <sw-icon name=\"regular-tablet\" small></sw-icon>\n                            {{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.device.tablet') }}\n                        </div>\n                        <sw-select-field\n                            v-model:value=\"viewTablet\"\n                            size=\"small\"\n                            :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.label')\"\n                            :placeholder=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.placeholder')\"\n                            @change=\"onElementUpdate\"\n                        >\n                            <option value=\"carousel\">{{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.carousel') }}</option>\n                            <option value=\"grid\">{{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.grid') }}</option>\n                        </sw-select-field>\n                        <sw-number-field\n                            v-model:value=\"itemsTablet\"\n                            size=\"small\"\n                            :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.items.label')\"\n                            number-type=\"int\"\n                            :min=\"1\"\n                            :allow-empty=\"true\"\n                            :disabled=\"viewTablet === 'grid'\"\n                            @change=\"onElementUpdate\"\n                            @update:value=\"onElementUpdate\"\n                        >\n                        </sw-number-field>\n                    </div>\n\n                    <div>\n                        <div class=\"sw-cms-el-config-tweakwise-featured-products__display-column-header\">\n                            <sw-icon name=\"regular-mobile\" small></sw-icon>\n                            {{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.device.mobile') }}\n                        </div>\n                        <sw-select-field\n                            v-model:value=\"viewMobile\"\n                            size=\"small\"\n                            :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.label')\"\n                            :placeholder=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.placeholder')\"\n                            @change=\"onElementUpdate\"\n                        >\n                            <option value=\"carousel\">{{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.carousel') }}</option>\n                            <option value=\"grid\">{{ $tc('sw-cms.elements.tweakwiseFeaturedProducts.config.view.grid') }}</option>\n                        </sw-select-field>\n                        <sw-number-field\n                            v-model:value=\"itemsMobile\"\n                            size=\"small\"\n                            :label=\"$tc('sw-cms.elements.tweakwiseFeaturedProducts.config.items.label')\"\n                            number-type=\"int\"\n                            :min=\"1\"\n                            :allow-empty=\"true\"\n                            :disabled=\"viewMobile === 'grid'\"\n                            @change=\"onElementUpdate\"\n                            @update:value=\"onElementUpdate\"\n                        >\n                        </sw-number-field>\n                    </div>\n\n                </div>\n            </template>\n        </template>\n    </sw-tabs>\n{% endblock %}";