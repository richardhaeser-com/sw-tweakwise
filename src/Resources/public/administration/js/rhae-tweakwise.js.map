export default "<div :isLoading=\"isLoading\" class=\"tweakwise-sync\">\n    <sw-container v-if=\"product && product.childCount\">\n        <mt-banner\n                variant=\"attention\"\n                class=\"sw-bulk-edit-save-modal__warning\"\n        >\n            {{ $tc('sw-product.detail.tab.variants') }}\n        </mt-banner>\n\n    </sw-container>\n\n\n    <template v-for=\"frontend in frontends\">\n        <sw-card :title=\"frontend.name\" v-if=\"frontend.accessToken && frontend.backendSyncEnabled\">\n            <sw-container\n                    columns=\"1fr 1fr\"\n                    gap=\"10px 30px\"\n            >\n                <div>\n                    {{ $tc('sw-product.detail.tab.productId') }}\n                </div>\n                <div>\n                    {{ productId[frontend.id] }}\n                </div>\n                <div>\n                    {{ $tc('sw-product.detail.tab.available') }}\n                </div>\n                <div>\n                    <span v-if=\"availability[frontend.id]\">{{ $tc('sw-product.detail.tab.availableYes') }}</span>\n                    <span v-else>{{ $tc('sw-product.detail.tab.availableNo') }}</span>\n                </div>\n                <div v-if=\"availability[frontend.id]\">\n                    {{ $tc('sw-product.detail.tab.lastModified') }}\n                </div>\n                <div v-if=\"availability[frontend.id]\">\n                    <sw-time-ago\n                            :date=\"new Date(tweakwiseData[frontend.id].LastModified)\"\n                            :date-time-format=\"{ month: '2-digit', day: '2-digit' }\"\n                    />\n                </div>\n                <div>\n                    <sw-button\n                            :isLoading=\"isLoading\"\n                            size=\"small\"\n                            variant=\"primary\"\n                            @click=\"onSync(frontend.id, productId[frontend.id])\"\n                    >\n                        {{ $tc('sw-product.detail.tab.sync') }}\n                    </sw-button>\n                </div>\n            </sw-container>\n\n        </sw-card>\n        <sw-card :title=\"frontend.name\" v-if=\"!frontend.accessToken\">\n            <mt-banner\n                    variant=\"attention\"\n                    class=\"sw-bulk-edit-save-modal__warning\"\n            >\n                {{ $tc('sw-product.detail.tab.noAccessToken') }}\n            </mt-banner>\n        </sw-card>\n    </template>\n</div>\n";